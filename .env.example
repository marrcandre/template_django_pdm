# ============================================================
# Projeto Livraria - Configuração de Ambiente
#
# Todas as configurações específicas do ambiente devem ser
# realizadas neste arquivo, conforme a metodologia
# Twelve-Factor App:
# https://12factor.net/pt_br/config
# Saiba mais assistindo ao vídeo do Fábio Akita:
# https://youtu.be/gpJgtED36U4
# ============================================================

# ------------------------------------------------------------------
# Segurança
# ------------------------------------------------------------------

# A chave secreta do Django é utilizada internamente para assinar
# sessões, tokens e outras informações sensíveis da aplicação.
# Ela deve ser mantida em segredo e nunca compartilhada publicamente.
# Para gerar uma nova chave secreta, você
# pode utilizar o comando a seguir no terminal:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'

SECRET_KEY=django-insecure

# Em produção, a variável DEBUG deve ser definida como False para evitar
# a exibição de informações sensíveis em caso de erro. Em desenvolvimento,
# é recomendável mantê-la como True para facilitar a depuração.

DEBUG=True

# ------------------------------------------------------------------
# Banco de Dados
# ------------------------------------------------------------------

# Desenvolvimento (SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# Exemplo para produção (Fabroku)
# DATABASE_URL=postgres://usuario:senha@host:5432/banco
#
# Observação:
# Ao criar um serviço de Banco de Dados no Fabroku, a variável
# DATABASE_URL é criada automaticamente e disponibilizada para
# sua aplicação. Normalmente não é necessário criá-la manualmente.

# ------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------

# Frontends autorizados a acessar a API.
#
# Em desenvolvimento utilizamos localhost e 127.0.0.1, pois,
# embora apontem para o mesmo computador, o navegador os trata
# como origens (origins) diferentes para fins de segurança.
#
# Informe uma ou mais URLs separadas por vírgula.

FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

# Exemplo para publicação utilizando o Fabroku:
# FRONTEND_URLS=https://meu-projeto.class.fabricadesoftware.ifc.edu.br

# Exemplo para publicação utilizando o Vercel:
# FRONTEND_URLS=https://meu-projeto.vercel.app

# Se você tem o frontend publicado em ambos os serviços, Fabroku e Vercel, você pode informar as duas URLs:
# FRONTEND_URLS=https://meu-projeto.class.fabricadesoftware.ifc.edu.br,https://meu-projeto.vercel.app

# ------------------------------------------------------------------
# Cloudinary (opcional)
# ------------------------------------------------------------------

# Quando definida, os arquivos enviados pelos usuários serão
# armazenados no Cloudinary.
#
# Caso fique vazia, os arquivos serão armazenados localmente
# na pasta media/.

CLOUDINARY_URL=

# Exemplo:
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
